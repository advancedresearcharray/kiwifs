{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "KiwiFS is a content-addressable file system with an API.",
        "title": "KiwiFS API",
        "contact": {
            "name": "KiwiFS Support",
            "url": "https://github.com/kiwifs/kiwifs"
        },
        "license": {
            "name": "Business Source License 1.1",
            "url": "https://github.com/kiwifs/kiwifs/blob/main/LICENSE"
        },
        "version": "1.0"
    },
    "host": "localhost:3333",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Returns simple health status",
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/healthz": {
            "get": {
                "description": "Returns health status with uptime and version",
                "tags": [
                    "health"
                ],
                "summary": "Detailed health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "description": "Returns Prometheus-formatted metrics",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Prometheus metrics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/readyz": {
            "get": {
                "description": "Returns readiness status including storage and protocol health",
                "tags": [
                    "health"
                ],
                "summary": "Readiness check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.readyResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.readyResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.protocolStatus": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "endpoint": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                },
                "healthy": {
                    "type": "boolean"
                },
                "port": {
                    "type": "integer"
                }
            }
        },
        "api.readyResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "protocols": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/api.protocolStatus"
                    }
                },
                "status": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Type \"Bearer \" followed by your API key.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}